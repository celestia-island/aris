# Gateway provisioning environment.
# This file is sourced by /etc/init.d/S90evernight at boot.
# Set these values during device provisioning (factory or first-boot setup).

# WebSocket URL of the upstream entelecheia / evernight-server.
# The gateway sends device.register + device.telemetry here.
GATEWAY_URL="ws://entelecheia.local:8443/api/ws"

# Unique device identifier (default: hostname).
# Set to a provisioned UUID or MAC-based ID for production.
NODE_ID=""

# Path to the hardware manifest TOML (station register maps, alarm rules).
# When absent, evernight falls back to serial port auto-detection.
MANIFEST="/etc/evernight/manifest.toml"

# Local WebSocket API port for remote control commands.
API_PORT="50000"
