#!/bin/sh
# /etc/init.d/S50usbgadget — start USB composite gadget at boot.
#
# Configures the USB-C port as a composite gadget device:
#   1. mass_storage — virtual USB drive with per-OS auto-installer
#   2. ncm          — virtual Ethernet adapter for gateway ↔ host comms
#
# This runs before S90evernight so that the USB network is up before
# evernight tries to register with the cloud.

NAME="aris-usb-gadget"
SCRIPT="/usr/sbin/${NAME}"

case "$1" in
    start)
        echo "Starting ${NAME}..."
        "${SCRIPT}" start
        ;;
    stop)
        echo "Stopping ${NAME}..."
        "${SCRIPT}" stop
        ;;
    restart)
        "$0" stop
        sleep 1
        "$0" start
        ;;
    status)
        "${SCRIPT}" status
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac
