#!/bin/sh
# /etc/init.d/S90evernight — start evernight gateway daemon on boot.
#
# evernight runs in two modes on the gateway:
#   1. sensor-poll  — polls Modbus/S7comm/MC devices, sends telemetry to cloud
#   2. api-serve    — WebSocket API for remote control commands
#
# This script starts both. aris-core (PID 1) calls this during boot.
#
# Config is sourced from /etc/evernight/gateway.env (provisioning-time).

NAME="evernight"
DAEMON="/usr/bin/$NAME"
PIDDIR="/var/run"
CONFIG_DIR="/etc/evernight"

# Source gateway environment if available
if [ -f "$CONFIG_DIR/gateway.env" ]; then
    . "$CONFIG_DIR/gateway.env"
fi

# Defaults (overridden by gateway.env)
GATEWAY_URL="${GATEWAY_URL:-ws://entelecheia.local:8443/api/ws}"
NODE_ID="${NODE_ID:-$(hostname)}"
MANIFEST="${MANIFEST:-/etc/evernight/manifest.toml}"
API_PORT="${API_PORT:-50000}"

start_sensor_poll() {
    echo "Starting $NAME sensor-poll..."
    ARGS="sensor-poll"
    ARGS="$ARGS --gateway $GATEWAY_URL"
    ARGS="$ARGS --node-id $NODE_ID"
    if [ -f "$MANIFEST" ]; then
        ARGS="$ARGS --manifest $MANIFEST"
    fi
    start-stop-daemon -S -b -m -p "$PIDDIR/$NAME-sensor.pid" \
        -x "$DAEMON" -- $ARGS
}

start_api_serve() {
    echo "Starting $NAME api-serve..."
    start-stop-daemon -S -b -m -p "$PIDDIR/$NAME-api.pid" \
        -x "$DAEMON" -- api-serve --transport ws --host 0.0.0.0 --port $API_PORT
}

stop_daemon() {
    local pidfile="$1"
    if [ -f "$pidfile" ]; then
        start-stop-daemon -K -p "$pidfile" 2>/dev/null
        rm -f "$pidfile"
    fi
}

case "$1" in
    start)
        start_sensor_poll
        start_api_serve
        ;;
    stop)
        stop_daemon "$PIDDIR/$NAME-sensor.pid"
        stop_daemon "$PIDDIR/$NAME-api.pid"
        ;;
    restart)
        "$0" stop
        sleep 1
        "$0" start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac
