# Kernel config fragment for NanoPi R3S (RK3566)
# Applied on top of arch/arm64/configs/defconfig

# Architecture
CONFIG_ARM64=y
CONFIG_ARCH_ROCKCHIP=y

# RK3566 SoC
CONFIG_ROCKCHIP_PHY=y
CONFIG_ROCKCHIP_GRF=y
CONFIG_ROCKCHIP_IODOMAIN=y

# Ethernet (DWMAC / stmmac)
CONFIG_STMMAC_ETH=y
CONFIG_STMMAC_PLATFORM=y
CONFIG_DWMAC_ROCKCHIP=y
CONFIG_R8169=n

# GPIO & Pinctrl
CONFIG_GPIO_ROCKCHIP=y
CONFIG_PINCTRL_RK3566=y

# SPI
CONFIG_SPI=y
CONFIG_SPI_ROCKCHIP=y
CONFIG_SPI_BITBANG=y
CONFIG_SPI_SPIDEV=y

# I2C
CONFIG_I2C=y
CONFIG_I2C_CHARDEV=y
CONFIG_I2C_RK3X=y

# UART
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_DW=y
CONFIG_SERIAL_OF_PLATFORM=y

# Storage
CONFIG_MMC=y
CONFIG_MMC_DW=y
CONFIG_MMC_DW_ROCKCHIP=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PLTFM=y
CONFIG_MMC_SDHCI_OF_DWCMSHC=y

# USB host controllers
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_OHCI_HCD=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_ROCKCHIP=y
CONFIG_USB_DWC3_DUAL_ROLE=y
CONFIG_USB_DWC3_HOST=y
CONFIG_USB_DWC3_GADGET=y

# USB PHY (Rockchip)
CONFIG_PHY_ROCKCHIP_USB2=y
CONFIG_PHY_ROCKCHIP_INNO_USB2=y
CONFIG_PHY_ROCKCHIP_SNPS_PCIE3=y

# USB gadget framework
CONFIG_USB_GADGET=y
CONFIG_USB_GADGET_CONFIGFS=y
CONFIG_USB_LIBCOMPOSITE=y
CONFIG_USB_CONFIGFS_ACM=y
CONFIG_USB_CONFIGFS_ECM=y
CONFIG_USB_CONFIGFS_ECM_SUBSET=y
CONFIG_USB_CONFIGFS_RNDIS=y
CONFIG_USB_CONFIGFS_EEM=y
CONFIG_USB_CONFIGFS_MASS_STORAGE=y
CONFIG_USB_CONFIGFS_F_LB_SS=y
CONFIG_USB_CONFIGFS_F_FS=y
CONFIG_USB_CONFIGFS_F_UAC1=y
CONFIG_USB_CONFIGFS_F_UAC2=y
CONFIG_USB_CONFIGFS_F_UVC=y

# Mass-storage backing-file support
CONFIG_BLK_DEV_LOOP=y
CONFIG_ISO9660_FS=y

# USB gadget networking (CDC NCM is preferred for Linux/macOS,
# RNDIS is needed for Windows compatibility)
CONFIG_USB_NET_DRIVERS=y
CONFIG_USB_USBNET=y
CONFIG_USB_NET_CDCETHER=y
CONFIG_USB_NET_RNDIS_HOST=y
CONFIG_USB_NET_CDC_NCM=y

# Watchdog
CONFIG_WATCHDOG=y
CONFIG_DW_WATCHDOG=y

# Hardware RNG
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_ROCKCHIP=y

# Networking
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IP_PNP=y
CONFIG_IP_PNP_DHCP=y
CONFIG_PACKET=y
CONFIG_UNIX=y

# File systems
CONFIG_EXT4_FS=y
CONFIG_VFAT_FS=y
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_XZ=y
CONFIG_TMPFS=y
CONFIG_OVERLAY_FS=y
CONFIG_DM_VERITY=y

# Reduce kernel size
CONFIG_EMBEDDED=y
CONFIG_EXPERT=y
